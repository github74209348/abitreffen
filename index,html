<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Abitreffen Einladung</title>

<meta property="og:title" content="30 Jahre Abitreffen">
<meta property="og:description" content="Sei dabei – wir sehen uns wieder!">
<meta property="og:image" content="poster.png">

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f5f5f5;
}

a {
  text-decoration: none;
  color: inherit;
}

/* DESKTOP */
.desktop-layout {
  display: block;
  max-width: 800px;
  margin: auto;
  position: relative;
}

.desktop-layout img {
  width: 100%;
  display: block;
  border-radius: 12px;
}

.desktop-layout .button {
  position: absolute;
  background: rgba(255,255,255,0.9);
  border-radius: 20px;
  padding: 10px 14px;
  font-size: 14px;
  font-weight: bold;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  cursor: pointer;
}

/* MOBILE */
.mobile-layout {
  display: none;
  max-width: 800px;
  margin: auto;
}

.mobile-layout img {
  width: 100%;
  display: block;
  border-radius: 12px;
}

.button-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 12px;
  margin-top: 0;
}

.mobile-layout .button {
  background: rgba(255,255,255,0.95);
  border-radius: 18px;
  padding: 12px;
  font-size: 14px;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  cursor: pointer;
}

.primary {
  background: #ff4081 !important;
  color: white;
}

.full {
  grid-column: span 2;
}

/* MODAL */
#infoModalOverlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: none;
  z-index: 9999;
}

#infoModal {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  background: white;
  color: black;
  padding: 20px 25px;
  border-radius: 12px;
  max-width: 600px;
  width: 85%;
  text-align: center;
  font-size: 15px;
  line-height: 1.4;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

/* SWITCH */
@media (max-width: 768px) {
  .desktop-layout { display: none; }
  .mobile-layout { display: block; }
}
</style>
</head>

<body>

<!-- AUDIO -->
<audio id="partySound" src="party.mp3" preload="auto"></audio>

<!-- DESKTOP -->
<div class="desktop-layout">

<img src="poster.png" alt="Abitreffen Einladung">

<a href="https://www.google.com/maps/search/?api=1&query=Humboldt+Kaffeemanufaktur+Seelingstraße+32+Berlin"
   target="_blank"
   class="button"
   style="top:60%; left:45%;"
   onclick="triggerFirstInteraction()">
📍 Ort
</a>

<div class="button"
     style="top:70%; left:45%;"
     onclick="openInfoModal(); triggerFirstInteraction();">
🕒 Info
</div>

<a href="https://cdn.shopify.com/s/files/1/0845/5726/7270/files/Karte_ab_April_25.pdf?v=1745924336#page=3"
   target="_blank"
   class="button"
   style="top:80%; left:45%;"
   onclick="triggerFirstInteraction()">
🍸 Getränkekarte
</a>

<a href="https://DEINE-NEXTCLOUD-URL"
   target="_blank"
   class="button"
   style="top:99%; left:10%;"
   onclick="playPartySound(); triggerFirstInteraction()">
✅ Teilnahme zusagen
</a>

<a href="https://DEINE-NEXTCLOUD-URL"
   target="_blank"
   class="button"
   style="top:99%; left:40%;"
   onclick="triggerFirstInteraction()">
👥 Teilnehmer ansehen
</a>

</div>

<!-- INFO MODAL -->
<div id="infoModalOverlay" onclick="closeInfoModal()">
  <div id="infoModal">
    Wer sich schon früher treffen möchte, kann dies gerne eigenorganisiert in der Location tun.  
    Während des regulären Betriebs können wir für euch Tische reservieren.  
    Bitte meldet euch mit der gewünschten Personenanzahl.
  </div>
</div>

<!-- MOBILE -->
<div class="mobile-layout">

<img src="poster.png" alt="Abitreffen Einladung">

<div class="button-grid">

<a href="https://www.google.com/maps/search/?api=1&query=Humboldt+Kaffeemanufaktur+Seelingstraße+32+Berlin"
   target="_blank"
   class="button"
   onclick="triggerFirstInteraction()">
📍 Ort
</a>

<div class="button"
     onclick="openInfoModal(); triggerFirstInteraction();">
🕒 Info
</div>

<a href="https://cdn.shopify.com/s/files/1/0845/5726/7270/files/Karte_ab_April_25.pdf?v=1745924336#page=3"
   target="_blank"
   class="button"
   onclick="triggerFirstInteraction()">
🍸 Getränkekarte
</a>

<a href="https://DEINE-NEXTCLOUD-URL"
   target="_blank"
   class="button primary"
   onclick="playPartySound(); triggerFirstInteraction()">
✅ Teilnahme zusagen
</a>

<a href="https://DEINE-NEXTCLOUD-URL"
   target="_blank"
   class="button full"
   onclick="triggerFirstInteraction()">
👥 Teilnehmer ansehen
</a>

</div>

</div>

<script>
let infoTimer;
let soundPlayedOnce = false;

function playPartySound() {
  const sound = document.getElementById("partySound");
  if (sound) {
    sound.currentTime = 0;
    sound.play().catch(e => console.log("Audio blocked:", e));
  }
}

function triggerFirstInteraction() {
  if (!soundPlayedOnce) {
    playPartySound();
    soundPlayedOnce = true;
  }
}

function openInfoModal() {
  const modal = document.getElementById("infoModalOverlay");
  modal.style.display = "block";

  clearTimeout(infoTimer);
  infoTimer = setTimeout(closeInfoModal, 10000);
}

function closeInfoModal() {
  document.getElementById("infoModalOverlay").style.display = "none";
}
</script>

</body>
</html>
